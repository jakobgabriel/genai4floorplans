{
  "name": "@flowplan/docs",
  "version": "0.0.0",
  "private": true,
  "description": "FlowPlan documentation site (Docusaurus). A standalone package with its own node_modules and no \"type\": \"module\", isolating Docusaurus's SSR build from the ESM monorepo root (Docusaurus does not support type:module).",
  "scripts": {
    "api": "typedoc",
    "build": "npm run api && docusaurus build",
    "start": "npm run api && docusaurus start",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "typedoc": "^0.28.5",
    "typedoc-plugin-markdown": "^4.4.0",
    "typescript": "^5.6.3"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": ["last 3 chrome version", "last 3 firefox version", "last 5 safari version"]
  },
  "engines": {
    "node": ">=18.0"
  }
}
