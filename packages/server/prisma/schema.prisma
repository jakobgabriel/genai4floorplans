// FlowPlan database schema. Each cell/scenario stores its full domain Model as a
// JSONB column (models are small; @flowplan/core/migrate owns intra-JSON schema
// evolution, so a SCHEMA_VERSION bump needs no Prisma migration). A denormalized
// schemaVersion column enables lazy migrate-on-read and bulk sweeps.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

enum AiProviderId {
  CLAUDE
  OPENAI
}

enum AiCapability {
  PROPOSE
  NARRATE
  EDIT
  INGEST
  DESIGN
  INGEST_IMAGE
  OPTIMIZE_GOAL
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String? // null when OAuth-only
  createdAt    DateTime     @default(now())
  memberships  Membership[]
  aiUsage      AiUsageLog[]
}

model Team {
  id            String             @id @default(cuid())
  name          String
  createdAt     DateTime           @default(now())
  memberships   Membership[]
  workspaces    Workspace[]
  aiCreds       TeamAiCredential[]
  aiUsage       AiUsageLog[]
  libraryEntries LibraryEntry[]
  subflows      Subflow[]
}

// Process library. A LibraryEntry is a standard building block (the client's
// ProcessCatalogEntry, stored as JSON). teamId null = the GLOBAL seed catalog
// shared by everyone; teamId set = a team's own custom entry. This matches the
// locked "global catalog + per-team customs" model.
model LibraryEntry {
  id        String   @id @default(cuid())
  teamId    String? // null = global catalog
  entry     Json // the full ProcessCatalogEntry payload
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// A grouped/subflow element (node-RED subflow): member stations + internal flows,
// stored as JSON. Team-scoped and reusable across the team's workspaces.
model Subflow {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  data      Json // { stations, flows, w, h, category }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Workspace {
  id        String     @id @default(cuid())
  teamId    String
  name      String
  activeId  String? // mirrors Workspace.activeId; soft reference to a Cell.id
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  folders   Folder[]
  concepts  Concept[]
  cells     Cell[]
  scenarios Scenario[]

  @@index([teamId])
}

// Arbitrarily-nested folders organize layouts (cells) and scenarios within a
// workspace. parentId null = top-level (workspace root); position orders siblings
// within a parent. Deleting a folder reparents its contents up one level (the
// route does this explicitly); SetNull on Cell/Scenario is the integrity backstop.
model Folder {
  id          String     @id @default(cuid())
  workspaceId String
  parentId    String? // null = top-level
  name        String
  position    Int        @default(0)
  archived    Boolean    @default(false) // soft-deleted, recoverable from the Archive
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]   @relation("FolderTree")
  concepts    Concept[]
  cells       Cell[]
  scenarios   Scenario[]

  @@index([workspaceId])
  @@index([parentId])
}

// A Concept is the workspace item: one manufacturing concept, living in a folder
// and holding one or more layouts (Cells). Mirrors Folder's placement fields.
// Deleting a concept cascades to its cells (a layout can't exist without one).
model Concept {
  id          String    @id @default(cuid())
  workspaceId String
  folderId    String? // null = workspace root
  name        String
  position    Int       @default(0)
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  cells       Cell[]

  @@index([workspaceId])
  @@index([folderId])
}

model Cell {
  id            String    @id @default(cuid())
  workspaceId   String
  folderId      String? // null = workspace root; mirrors the owning concept's folder
  conceptId     String? // the owning concept (workspace item)
  name          String
  schemaVersion Int // denormalized copy of model.schemaVersion
  model         Json // the full Model object (JSONB)
  position      Int       @default(0) // order among siblings in the concept
  archived      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder        Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  concept       Concept?  @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([folderId])
  @@index([conceptId])
}

model Scenario {
  id            String    @id @default(cuid())
  workspaceId   String
  folderId      String? // null = workspace root
  name          String
  schemaVersion Int
  model         Json // full Model snapshot (the saved variant)
  savedAt       DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder        Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, name]) // matches localStorage keyed-by-name semantics
  @@index([workspaceId])
  @@index([folderId])
}

model TeamAiCredential {
  id            String       @id @default(cuid())
  teamId        String
  provider      AiProviderId
  model         String // e.g. "claude-sonnet-4-6", "gpt-4o"
  keyCiphertext Bytes // AES-256-GCM ciphertext of the API key
  keyIv         Bytes // 12-byte GCM nonce
  keyTag        Bytes // 16-byte GCM auth tag
  createdAt     DateTime     @default(now())
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, provider]) // one key per provider per team
}

model AiUsageLog {
  id         String       @id @default(cuid())
  teamId     String
  userId     String
  provider   AiProviderId
  capability AiCapability
  model      String
  ok         Boolean
  latencyMs  Int
  errorCode  String? // when ok=false
  createdAt  DateTime     @default(now())
  team       Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
}
