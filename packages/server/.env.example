# FlowPlan API server configuration. Copy to .env and fill in real values.

# Postgres connection string.
DATABASE_URL="postgresql://flowplan:flowplan@localhost:5432/flowplan?schema=public"

# Secret for signing session JWTs (use a long random string in production).
JWT_SECRET="change-me-to-a-long-random-string"

# Base64-encoded 32-byte key for AES-256-GCM encryption of stored AI keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENC_KEY=""

# Where the SPA is served from (for CORS).
CORS_ORIGIN="http://localhost:5173"

# Optional env-level AI fallback keys, used when a team has no stored credential.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

PORT=4000
