{
  "name": "flowplan-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FlowPlan — cell & material-flow assessment tool for manufacturing",
  "workspaces": [
    "packages/core",
    "packages/web",
    "packages/server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @flowplan/web",
    "build": "npm run build --workspace @flowplan/web",
    "preview": "npm run preview --workspace @flowplan/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run test:integration --workspace @flowplan/server",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
