{
  "name": "flowplan-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FlowPlan — cell & material-flow assessment tool for manufacturing",
  "workspaces": [
    "packages/core",
    "packages/web",
    "packages/server"
  ],
  "scripts": {
    "start": "docker compose up --build",
    "dev": "concurrently -k -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace @flowplan/web",
    "dev:api": "npm run dev --workspace @flowplan/server",
    "dev:all": "npm run dev",
    "dev:fresh": "npm run setup && npm run dev",
    "setup": "npm run db:setup",
    "db:setup": "npm run prisma:generate --workspace @flowplan/server && npm run prisma:deploy --workspace @flowplan/server && npm run db:seed --workspace @flowplan/server",
    "build": "npm run build --workspace @flowplan/web",
    "preview": "npm run preview --workspace @flowplan/web",
    "pretest": "npm run prisma:generate --workspace @flowplan/server",
    "test": "vitest run",
    "pretest:watch": "npm run prisma:generate --workspace @flowplan/server",
    "test:watch": "vitest",
    "test:integration": "npm run test:integration --workspace @flowplan/server",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
