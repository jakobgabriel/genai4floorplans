# Optional overrides for `docker compose up`. The stack runs with safe dev
# defaults WITHOUT this file; copy to `.env` and fill in real values for any
# deployment that isn't throwaway-local. Compose auto-loads `.env`.

# Session JWT signing secret — use a long random string in production.
JWT_SECRET=dev-insecure-jwt-secret-change-me

# Base64-encoded 32-byte key for AES-256-GCM encryption of stored AI keys.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: changing this invalidates AI credentials already stored in the DB.
MASTER_ENC_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Postgres credentials (used by both the db and app services).
POSTGRES_USER=flowplan
POSTGRES_PASSWORD=flowplan
POSTGRES_DB=flowplan

# Host port the app is published on.
PORT=4000

# Optional env-level AI fallback keys, used when a team has no stored credential.
# Leave empty to default to the offline deterministic strategist.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
